# Copy to .env.local for development. On Vercel, add the same keys in Project → Settings → Environment Variables.

# Required for Sanity (read-only is fine without a token)
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=

# Optional
VITE_SANITY_API_VERSION=2026-04-25
# Default is false (no CDN) so home-page toggles show quickly; set true in prod if you prefer edge caching.
VITE_SANITY_USE_CDN=false

# Optional: only if server routes need an authenticated Sanity client
SANITY_API_TOKEN=
